{
  "manifest_version": 3,
  "name": "MailCheckr",
  "version": "1.1",
  "description": "Advanced email safety inspector with automated header analysis, link scanning and phishing alerts.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://mailcheckr.onrender.com/*",
    "https://mail.google.com/*",
    "http://ip-api.com/*"
  ],

  "background": {
    "service_worker": "scripts/background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://mail.google.com/*"],
      "js": ["scripts/content.js"],
      "run_at": "document_idle"
    }
  ]
}
